# Copy to .env for local process-based development and replace placeholders.
TRAVEL_AGENT_APP_NAME=AI Travel Agent API
TRAVEL_AGENT_APP_VERSION=0.1.0
TRAVEL_AGENT_ENVIRONMENT=development
TRAVEL_AGENT_LOG_LEVEL=INFO
TRAVEL_AGENT_DATABASE_URL=postgresql+psycopg://travel_agent:replace-me@localhost:5432/travel_agent
TRAVEL_AGENT_REDIS_URL=redis://:replace-me@localhost:6379/0
TRAVEL_AGENT_QDRANT_URL=http://localhost:6333
TRAVEL_AGENT_QDRANT_API_KEY=
TRAVEL_AGENT_QDRANT_MEMORY_COLLECTION=travel_memories
TRAVEL_AGENT_OPENAI_API_KEY=
TRAVEL_AGENT_OPENAI_MODEL=gpt-5.6-sol
TRAVEL_AGENT_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
TRAVEL_AGENT_AUTH_DISABLED=true
TRAVEL_AGENT_AUTH_ISSUER=
TRAVEL_AGENT_AUTH_AUDIENCE=
TRAVEL_AGENT_AUTH_JWKS_URL=
TRAVEL_AGENT_CORS_ORIGINS=["http://localhost:3000"]
TRAVEL_AGENT_ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]
TRAVEL_AGENT_MCP_SERVERS={}
TRAVEL_AGENT_MCP_TOOLS=[]
